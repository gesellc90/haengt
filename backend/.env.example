# Port, auf dem die Express-API hört
PORT=3001

# Pfad zur SQLite-Datenbankdatei (relativ zum Backend-Root oder absolut)
DB_PATH=./data/getraenke.db

# Log-Level für pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Node-Environment
NODE_ENV=development

# JWT — mindestens 32 Zeichen, zufällig generiert (z. B. openssl rand -base64 48)
# Niemals diesen Wert in die Versionskontrolle einchecken!
JWT_SECRET=replace-me-with-at-least-32-random-characters-generated-by-openssl
JWT_EXPIRES_IN=8h

# Verzeichnis für Profilbilder (wird beim Start angelegt, falls nicht vorhanden)
AVATAR_DIR=./data/avatars

# Verzeichnis für den Auto-Update-Rückkanal (M14): update-status.json (vom
# Pi-Helper geschrieben) und update-requested (Marker-Datei, von dieser App
# geschrieben). Muss auf dem Pi mit /var/lib/getraenke übereinstimmen.
UPDATE_STATE_DIR=./data

# Anzahl vertrauenswürdiger Reverse-Proxy-Hops (Express "trust proxy").
# 0 = kein Proxy (Default, sicher). Hinter Caddy/nginx auf 1 setzen, damit das
# Login-Rate-Limiting die echte Client-IP statt der Proxy-IP sieht.
# NICHT auf > 0 setzen, wenn KEIN Proxy davorsteht (X-Forwarded-For wäre spoofbar).
TRUST_PROXY=0
