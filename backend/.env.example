# Port, auf dem die Express-API hört
PORT=3001

# Pfad zur SQLite-Datenbankdatei (relativ zum Backend-Root oder absolut)
DB_PATH=./data/getraenke.db

# Log-Level für pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Node-Environment
NODE_ENV=development

# JWT — mindestens 32 Zeichen, zufällig generiert (z. B. openssl rand -base64 48)
# Niemals diesen Wert in die Versionskontrolle einchecken!
JWT_SECRET=replace-me-with-at-least-32-random-characters-generated-by-openssl
JWT_EXPIRES_IN=8h
