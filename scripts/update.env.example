# scripts/update.env.example
#
# Konfiguration für den Auto-Update-Helper (scripts/pi-self-update.sh, M14).
#
# Installation auf dem Pi:
#   sudo install -d -m 0755 /etc/getraenke
#   sudo cp scripts/update.env.example /etc/getraenke/update.env
#   sudo "$EDITOR" /etc/getraenke/update.env   # Werte eintragen
#   sudo chown root:root /etc/getraenke/update.env
#   sudo chmod 0600 /etc/getraenke/update.env
#
# Nur für root lesbar — dieses Token darf NIE im getraenke-App-Prozess
# landen (der App-Dienst läuft unprivilegiert und liest diese Datei nicht;
# nur getraenke-update.service, das als root läuft, tut das).

# owner/repo des Projekts.
GITHUB_REPO=gesellc90/haengt

# Fine-Grained Personal Access Token mit AUSSCHLIESSLICH der Berechtigung
# "Contents: Read-only" für genau dieses Repository — kein Zugriff auf
# andere Repos, keine Schreibrechte. Erzeugen unter:
#   GitHub → Settings → Developer settings → Fine-grained tokens → Generate new token
# Repository access: "Only select repositories" → gesellc90/haengt
# Permissions: Repository permissions → Contents → Read-only
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
